# =============================================================================
# EduPlay — Environment Variables
# Copy this file to .env and fill in your values before running the project.
# =============================================================================

# ──────────────────────────────────────────────
# Backend (services/api)
# ──────────────────────────────────────────────

APP_ENV=development
APP_PORT=8080

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=eduplay
DB_PASSWORD=eduplay_password
DB_NAME=eduplay

# Redis
REDIS_URL=redis://localhost:6379

# Frontend URL (used for CORS, email links, etc.)
FRONTEND_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=noreply@yourdomain.com

# Google OAuth
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# Web Push (VAPID)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Midtrans Payment (optional)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_IS_PRODUCTION=false

# AI / Bot (optional)
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_API_KEY=sk-xxxx

# Sentry (optional)
SENTRY_DSN=

# Avatar uploads
AVATAR_UPLOAD_PATH=./uploads/avatars

# App secret (CSRF / misc signing)
APP_SECRET=change_me_to_another_long_random_secret

# ──────────────────────────────────────────────
# Frontend (apps/web) — must be prefixed NEXT_PUBLIC_ to be exposed to the browser
# ──────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_INTERSTITIAL_SLOT=1234567890
