{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "plugins": [
    "@trivago/prettier-plugin-sort-imports",
    "prettier-plugin-tailwindcss"
  ],
  "importOrder": [
    "^(react|react-dom|next)",
    "^@?\\w",
    "^@/lib/",
    "^@/components/",
    "^@/app/",
    "^\\./"
  ],
  "importOrderSeparation": false,
  "importOrderSortSpecifiers": true
}
